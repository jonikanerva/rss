{
  "$schema": "https://opencode.ai/config.json",
  "default_agent": "rpi-orchestrator",
  "model": "opencode/gpt-5.1-codex",
  "small_model": "opencode/gpt-5.1-mini",
  "share": "manual",
  "compaction": {
    "auto": true,
    "prune": true,
    "reserved": 12000
  },
  "permission": {
    "*": "ask",
    "read": {
      "*": "allow",
      "*.env": "deny",
      "*.env.*": "deny",
      "*.env.example": "allow"
    },
    "bash": {
      "*": "ask",
      "git status*": "allow",
      "git diff*": "allow",
      "git log*": "allow",
      "npm test*": "allow",
      "pnpm test*": "allow",
      "bun test*": "allow",
      "git push*": "deny",
      "rm -rf *": "deny"
    },
    "task": {
      "*": "deny"
    },
    "skill": {
      "*": "allow"
    }
  },
  "agent": {
    "rpi-orchestrator": {
      "description": "Primary orchestrator that auto-dispatches domain subagents based on prompt context",
      "mode": "primary",
      "temperature": 0.2,
      "permission": {
        "edit": "ask",
        "bash": "ask",
        "task": {
          "*": "deny",
          "research-analyst": "allow",
          "product-strategist": "allow",
          "roadmap-planner": "allow",
          "quality-gatekeeper": "allow",
          "integration-operator": "allow"
        }
      }
    },
    "build": {
      "permission": {
        "edit": "ask",
        "bash": {
          "*": "ask",
          "git status*": "allow",
          "git diff*": "allow"
        }
      }
    },
    "plan": {
      "permission": {
        "edit": "deny",
        "bash": "ask"
      }
    }
  },
  "mcp": {
    "linear": {
      "type": "remote",
      "url": "https://mcp.linear.app/sse",
      "enabled": false
    },
    "github": {
      "type": "remote",
      "url": "https://api.githubcopilot.com/mcp/",
      "enabled": false
    },
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "enabled": false
    }
  },
  "tools": {
    "linear_*": false,
    "github_*": false,
    "context7_*": false
  },
  "instructions": [
    "AGENTS.md",
    "docs/research/*.md",
    "docs/plans/*.md",
    "docs/operating-model/*.md",
    "docs/quality-gates/*.md"
  ]
}
