{
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "sandbox": {
    "filesystem": {
      "allowWrite": ["~/.gnupg", "~/.npm"]
    }
  },
  "permissions": {
    "allow": [
      "Bash(make:*)",
      "Bash(gh pr:*)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git branch:*)",
      "Bash(git switch:*)",
      "Bash(git checkout -b:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git push origin:*)",
      "Bash(git pull:*)",
      "Bash(git worktree:*)",
      "Bash(npx ctx7@latest:*)",
      "WebFetch(domain:github.com)",
      "WebFetch(domain:api.github.com)",
      "WebFetch(domain:raw.githubusercontent.com)",
      "WebFetch(domain:developer.apple.com)",
      "WebFetch(domain:context7.com)",
      "WebFetch(domain:mcp.context7.com)"
    ],
    "deny": [
      "Bash(git push --force:*)",
      "Bash(git push origin main:*)",
      "Bash(rm -rf:*)",
      "Bash(claude:*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Read",
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'if echo \"$CLAUDE_TOOL_INPUT\" | grep -q \".env\"; then echo \"BLOCKED: reading .env files is not allowed\" >&2; exit 2; fi'"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'if echo \"$CLAUDE_TOOL_INPUT\" | grep -Eq \"(^|[[:space:];|&])claude([[:space:]]|$)\"; then echo \"BLOCKED: spawn subagents via the Agent tool, not the claude CLI\" >&2; exit 2; fi'"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'if echo \"$CLAUDE_TOOL_INPUT\" | grep -q \"gh pr create\"; then echo \"PR created. Run /codereview to start review.\"; fi'"
          }
        ]
      }
    ]
  }
}
